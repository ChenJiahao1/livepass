# Gateway target
GATEWAY_BASE_URL=http://127.0.0.1:8081
CHANNEL_CODE=0001

# Auth
JWT=replace-with-user-jwt

# Order payload
PROGRAM_ID=10001
TICKET_CATEGORY_ID=40001
TICKET_USER_IDS=701,702
DISTRIBUTION_MODE=express
TAKE_TICKET_MODE=paper

# Scenario sizing
WARMUP_VUS=1
WARMUP_DURATION=15s
STEADY_VUS=4
STEADY_DURATION=60s
# Optional override. Default start time is warmup duration + iteration sleep + 1s guard.
# STEADY_START_TIME=16s
ITERATION_SLEEP_SECONDS=0
