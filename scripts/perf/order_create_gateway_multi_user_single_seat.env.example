# Gateway target
GATEWAY_BASE_URL=http://127.0.0.1:8081
CHANNEL_CODE=0001

# Order payload
PROGRAM_ID=10001
TICKET_CATEGORY_ID=40001
DISTRIBUTION_MODE=express
TAKE_TICKET_MODE=paper

# Multi-user user pool
# Create this JSON locally and keep real JWTs out of git.
USER_POOL_FILE=scripts/perf/order_create_gateway_multi_user_single_seat.user_pool.json

# Load profile
TARGET_QPS=20
DURATION=5s
PREALLOCATED_VUS=20
MAX_VUS=80
